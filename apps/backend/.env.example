# Leave MONGODB_URI empty to run in local seed mode (no database required).
MONGODB_URI=
MONGODB_DATABASE=wavepalace
FRONTEND_ORIGIN=http://localhost:3000

# Cloudflare R2 — required only for the mux service (POST /api/mux/*).
# Get these from the Cloudflare R2 dashboard → Manage R2 API Tokens.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wavepalace-media
R2_PUBLIC_BASE_URL=https://stream.wavepalace.live
