# WavePalace Environment Variables
# Copy to .env and fill in values. Never commit .env.

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE=wavepalace

# Frontend origin for CORS + email links
FRONTEND_ORIGIN=https://wavepalace.live

# Auth
ADMIN_SECRET=changeme-long-random-string
JWT_SECRET=changeme-long-random-secret
SESSION_TTL_DAYS=30

# Cloudflare R2 (media storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wavepalace-media
R2_PUBLIC_BASE_URL=https://stream.wavepalace.live

# Resend (transactional email)
RESEND_API_KEY=re_...

# Discord OAuth (Slice 9 — follow via Discord)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://wavepalace.live/api/auth/discord/callback

# Discord Bot (Slice 13 — DM notifications)
# Create at https://discord.com/developers/applications
# Enable "Bot" scope + "Send Messages" permission
# Invite URL: https://discord.com/api/oauth2/authorize?client_id=CLIENT_ID&scope=bot&permissions=2048
DISCORD_BOT_TOKEN=

# Web Push (VAPID — browser push notifications)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# DMCA takedown email notifications
ADMIN_EMAIL=admin@wavepalace.live
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# VRChat MP4 mux font path (Ubuntu default)
# FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf
